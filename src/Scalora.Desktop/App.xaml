<Application x:Class="Scalora.Desktop.App" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Application.Resources>
    <SolidColorBrush x:Key="PageBrush" Color="#F4F7FB"/><SolidColorBrush x:Key="NavyBrush" Color="#101B36"/><SolidColorBrush x:Key="AccentBrush" Color="#5B67F1"/>
    <Style TargetType="Button"><Setter Property="Cursor" Value="Hand"/><Setter Property="Padding" Value="14,9"/><Setter Property="BorderThickness" Value="0"/></Style>
    <Style x:Key="NavButton" TargetType="Button"><Setter Property="Foreground" Value="#B7C2DB"/><Setter Property="Background" Value="Transparent"/><Setter Property="HorizontalContentAlignment" Value="Left"/><Setter Property="FontSize" Value="14"/><Setter Property="Margin" Value="8,3"/></Style>
    <Style x:Key="Card" TargetType="Border"><Setter Property="Background" Value="White"/><Setter Property="CornerRadius" Value="12"/><Setter Property="Padding" Value="18"/><Setter Property="Margin" Value="6"/><Setter Property="Effect"><Setter.Value><DropShadowEffect BlurRadius="14" ShadowDepth="1" Opacity=".07"/></Setter.Value></Setter></Style>
  </Application.Resources>
</Application>
