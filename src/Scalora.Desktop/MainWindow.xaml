<Window x:Class="Scalora.Desktop.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Scalora POS ERP" Width="1440" Height="900" MinWidth="1100" MinHeight="700" WindowStartupLocation="CenterScreen" Background="{StaticResource PageBrush}">
  <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="230"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
    <Border Background="{StaticResource NavyBrush}"><DockPanel>
      <StackPanel DockPanel.Dock="Top"><TextBlock Text="SCALORA" Foreground="White" FontSize="25" FontWeight="Bold" Margin="24,28,24,3"/><TextBlock Text="POS + ERP" Foreground="#7483A4" Margin="25,0,24,28"/>
        <Button Style="{StaticResource NavButton}" Content="Dashboard" Command="{Binding ShowDashboardCommand}"/><Button Style="{StaticResource NavButton}" Content="Point of Sale" Command="{Binding ShowPosCommand}"/>
        <Button Style="{StaticResource NavButton}" Content="Products"/><Button Style="{StaticResource NavButton}" Content="Inventory"/><Button Style="{StaticResource NavButton}" Content="Customers"/><Button Style="{StaticResource NavButton}" Content="Suppliers"/>
        <Button Style="{StaticResource NavButton}" Content="Expenses"/><Button Style="{StaticResource NavButton}" Content="Reports"/><Button Style="{StaticResource NavButton}" Content="Shopify"/><Button Style="{StaticResource NavButton}" Content="Settings"/>
      </StackPanel><StackPanel DockPanel.Dock="Bottom" Margin="24"><TextBlock Text="{Binding UserName}" Foreground="White" FontWeight="SemiBold"/><TextBlock Text="{Binding ConnectionStatus}" Foreground="#7FE0B5" FontSize="12" Margin="0,4"/></StackPanel>
    </DockPanel></Border>
    <Grid Grid.Column="1" Margin="26"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
      <DockPanel Margin="5,0,5,18"><StackPanel><TextBlock Text="{Binding PageTitle}" FontSize="27" FontWeight="SemiBold" Foreground="#17213A"/><TextBlock Text="Real-time store overview" Foreground="#78849B" Margin="0,5"/></StackPanel>
        <Button DockPanel.Dock="Right" Content="Refresh" Command="{Binding RefreshCommand}" Background="{StaticResource AccentBrush}" Foreground="White" VerticalAlignment="Center"/>
      </DockPanel>
      <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"><Grid>
        <Grid x:Name="DashboardPanel" Visibility="{Binding DashboardVisibility}"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
          <UniformGrid Columns="4"><Border Style="{StaticResource Card}"><StackPanel><TextBlock Text="TODAY'S REVENUE" Foreground="#78849B"/><TextBlock Text="{Binding Revenue, StringFormat={}{0:C}}" FontSize="27" FontWeight="Bold" Margin="0,12,0,0"/></StackPanel></Border>
            <Border Style="{StaticResource Card}"><StackPanel><TextBlock Text="ORDERS" Foreground="#78849B"/><TextBlock Text="{Binding Orders}" FontSize="27" FontWeight="Bold" Margin="0,12,0,0"/></StackPanel></Border>
            <Border Style="{StaticResource Card}"><StackPanel><TextBlock Text="INVENTORY VALUE" Foreground="#78849B"/><TextBlock Text="{Binding InventoryValue, StringFormat={}{0:C}}" FontSize="27" FontWeight="Bold" Margin="0,12,0,0"/></StackPanel></Border>
            <Border Style="{StaticResource Card}"><StackPanel><TextBlock Text="LOW STOCK" Foreground="#78849B"/><TextBlock Text="{Binding LowStock}" FontSize="27" FontWeight="Bold" Foreground="#E45757" Margin="0,12,0,0"/></StackPanel></Border></UniformGrid>
          <Grid Grid.Row="1" Margin="0,18,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <Border Style="{StaticResource Card}"><StackPanel><TextBlock Text="Recent transactions" FontSize="18" FontWeight="SemiBold"/><DataGrid ItemsSource="{Binding RecentSales}" AutoGenerateColumns="False" IsReadOnly="True" BorderThickness="0" Margin="0,15"><DataGrid.Columns><DataGridTextColumn Header="Receipt" Binding="{Binding Receipt}" Width="*"/><DataGridTextColumn Header="Cashier" Binding="{Binding Cashier}" Width="*"/><DataGridTextColumn Header="Total" Binding="{Binding Total, StringFormat={}{0:C}}"/><DataGridTextColumn Header="Time" Binding="{Binding Time}"/></DataGrid.Columns></DataGrid></StackPanel></Border>
            <Border Grid.Column="1" Style="{StaticResource Card}"><StackPanel><TextBlock Text="Shopify sync" FontSize="18" FontWeight="SemiBold"/><TextBlock Text="Connected" Foreground="#1BAA78" FontWeight="SemiBold" Margin="0,18,0,5"/><TextBlock Text="{Binding PendingJobs, StringFormat='Pending jobs: {0}'}" Margin="0,5"/><TextBlock Text="{Binding FailedSyncs, StringFormat='Failed jobs: {0}'}" Foreground="#E45757" Margin="0,5"/><TextBlock Text="{Binding LastSync, StringFormat='Last sync: {0:g}'}" Foreground="#78849B" Margin="0,5"/></StackPanel></Border>
          </Grid></Grid>
        <Grid Visibility="{Binding PosVisibility}"><Grid.ColumnDefinitions><ColumnDefinition Width="3*"/><ColumnDefinition Width="2*"/></Grid.ColumnDefinitions>
          <StackPanel><TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" FontSize="16" Padding="14" Margin="6" ToolTip="Scan barcode or search products"/><ListBox ItemsSource="{Binding Products}" SelectedItem="{Binding SelectedProduct}" Margin="6"><ListBox.ItemTemplate><DataTemplate><DockPanel Margin="8"><TextBlock Text="{Binding Price, StringFormat={}{0:C}}" DockPanel.Dock="Right" FontWeight="Bold"/><StackPanel><TextBlock Text="{Binding Name}" FontWeight="SemiBold"/><TextBlock Text="{Binding Sku}" Foreground="#78849B"/></StackPanel></DockPanel></DataTemplate></ListBox.ItemTemplate></ListBox><Button Content="Add selected" Command="{Binding AddProductCommand}" Background="{StaticResource AccentBrush}" Foreground="White" Margin="6"/></StackPanel>
          <Border Grid.Column="1" Style="{StaticResource Card}"><DockPanel><StackPanel DockPanel.Dock="Bottom"><Separator Margin="0,12"/><DockPanel><TextBlock Text="Total" FontSize="21" FontWeight="Bold"/><TextBlock Text="{Binding CartTotal, StringFormat={}{0:C}}" FontSize="21" FontWeight="Bold" HorizontalAlignment="Right"/></DockPanel><Button Content="Charge" Command="{Binding CheckoutCommand}" Background="{StaticResource AccentBrush}" Foreground="White" FontSize="17" Margin="0,18,0,0"/></StackPanel><ListBox ItemsSource="{Binding Cart}" BorderThickness="0"/></DockPanel></Border>
        </Grid>
      </Grid></ScrollViewer>
    </Grid>
  </Grid>
</Window>
