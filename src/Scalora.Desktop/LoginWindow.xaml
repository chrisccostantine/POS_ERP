<Window x:Class="Scalora.Desktop.LoginWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sign in to Scalora" Width="430" Height="540" ResizeMode="NoResize" WindowStartupLocation="CenterScreen" Background="#F4F7FB">
  <Grid Margin="48"><StackPanel VerticalAlignment="Center">
    <TextBlock Text="SCALORA" Foreground="#5B67F1" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
    <TextBlock Text="Sign in to your store" Foreground="#17213A" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,35,0,25"/>
    <TextBlock Text="Email" Foreground="#59657B" Margin="0,0,0,7"/><TextBox x:Name="EmailBox" Text="admin@scalora.com" Padding="12" FontSize="15"/>
    <TextBlock Text="Password" Foreground="#59657B" Margin="0,18,0,7"/><PasswordBox x:Name="PasswordBox" Padding="12" FontSize="15"/>
    <TextBlock x:Name="ErrorText" Foreground="#D64545" TextWrapping="Wrap" Margin="0,12,0,0"/>
    <Button x:Name="LoginButton" Content="Sign in" Click="Login_Click" Background="#5B67F1" Foreground="White" FontSize="16" Margin="0,20,0,0"/>
    <TextBlock Text="Secure connection to Scalora Cloud" Foreground="#8A94A8" HorizontalAlignment="Center" Margin="0,22,0,0"/>
  </StackPanel></Grid>
</Window>
